<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cultural Experiences | Brisbane Olympic Visitor Guide</title>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">

<style>
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
    font-family: Arial, sans-serif;
}

html {
    scroll-behavior: smooth;
}

body {
    background-color: #f7f4ed;
    color: #1f2d3d;
    line-height: 1.6;
}

header {
    background: linear-gradient(rgba(0, 95, 115, 0.78), rgba(10, 147, 150, 0.66)),
                url("https://images.unsplash.com/photo-1526481280695-3c4691f77c52?auto=format&fit=crop&w=1600&q=80") center/cover no-repeat;
    color: white;
    min-height: 62vh;
}

nav {
    display: flex;
    justify-content: center;
    gap: 14px;
    padding: 18px;
    background: rgba(255, 255, 255, 0.10);
    backdrop-filter: blur(6px);
    flex-wrap: wrap;
}

nav a {
    text-decoration: none;
    color: white;
    font-weight: bold;
    padding: 10px 16px;
    border-radius: 999px;
}

nav a:hover,
.active-link {
    background-color: #ee9b00;
}

.hero {
    width: 90%;
    max-width: 1200px;
    margin: auto;
    padding: 60px 0;
    display: grid;
    grid-template-columns: 1.4fr 0.8fr;
    gap: 30px;
    align-items: center;
}

.hero h1 {
    font-size: 3rem;
    line-height: 1.1;
    margin-bottom: 16px;
}

.hero p {
    font-size: 1.08rem;
    max-width: 720px;
    margin-bottom: 24px;
}

.hero-buttons {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
}

.btn-primary,
.btn-secondary,
.btn-outline,
.button,
.flash-ok {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    padding: 12px 18px;
    border-radius: 10px;
    font-weight: bold;
    border: none;
    cursor: pointer;
    min-height: 42px;
    font-size: 0.95rem;
}

.btn-primary,
.button {
    background-color: #ee9b00;
    color: white;
}

.btn-primary:hover,
.button:hover {
    background-color: #ca6702;
}

.btn-secondary {
    background-color: rgba(255, 255, 255, 0.16);
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.35);
}

.btn-outline {
    background: white;
    color: #005f73;
    border: 1px solid #cfd8dc;
}

.hero-panel {
    background: rgba(255, 255, 255, 0.14);
    border: 1px solid rgba(255, 255, 255, 0.22);
    backdrop-filter: blur(8px);
    border-radius: 20px;
    padding: 24px;
}

.hero-panel h2 {
    margin-bottom: 10px;
}

.hero-panel ul {
    padding-left: 18px;
}

.flash-wrapper {
    width: 90%;
    max-width: 1200px;
    margin: 24px auto 0;
}

.flash-message {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 14px 18px;
    border-radius: 12px;
    margin-bottom: 12px;
    font-weight: bold;
    box-shadow: 0 6px 16px rgba(0, 95, 115, 0.10);
}

.flash-success {
    background: #e8f7e8;
    color: #256029;
    border-left: 5px solid #2e7d32;
}

.flash-error {
    background: #fdeaea;
    color: #9b2226;
    border-left: 5px solid #9b2226;
}

.flash-info {
    background: #e8f0fe;
    color: #1d4ed8;
    border-left: 5px solid #1d4ed8;
}

.flash-actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
}

.flash-ok,
.flash-link {
    background: white;
    color: #005f73;
    border: 1px solid #cfd8dc;
    min-height: 34px;
    padding: 8px 12px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: bold;
}

.container {
    width: 90%;
    max-width: 1250px;
    margin: 55px auto;
}

.section-header {
    text-align: center;
    margin-bottom: 28px;
}

.section-header h2 {
    font-size: 2.2rem;
    color: #005f73;
    margin-bottom: 10px;
}

.section-header p {
    max-width: 760px;
    margin: auto;
    color: #526170;
}

.role-notice {
    background: white;
    border-left: 5px solid #ee9b00;
    padding: 18px 20px;
    border-radius: 14px;
    margin-bottom: 30px;
    box-shadow: 0 8px 20px rgba(0, 95, 115, 0.08);
}

.role-notice strong {
    color: #005f73;
}

.highlight-banner {
    background: linear-gradient(135deg, #005f73, #0a9396);
    color: white;
    border-radius: 22px;
    padding: 30px;
    margin-bottom: 40px;
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 20px;
    align-items: center;
}

.highlight-box {
    background: rgba(255, 255, 255, 0.14);
    padding: 22px;
    border-radius: 18px;
    text-align: center;
}

.filter-bar {
    display: grid;
    grid-template-columns: 1.2fr 1fr 1fr 1fr 1fr auto;
    gap: 15px;
    margin-bottom: 18px;
    background: white;
    padding: 22px;
    border-radius: 18px;
    box-shadow: 0 8px 20px rgba(0, 95, 115, 0.10);
    border: 1px solid #e7ecec;
}

.filter-bar input,
.filter-bar select {
    width: 100%;
    padding: 12px;
    border: 1px solid #cfd8dc;
    border-radius: 10px;
    font-size: 0.95rem;
}

.results-bar {
    display: flex;
    justify-content: space-between;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 26px;
    color: #526170;
}

/* MAIN FIX: two cards per row so cards have more room */
.card-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 34px;
    align-items: stretch;
}

.card {
    background: white;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 8px 20px rgba(0, 95, 115, 0.10);
    border: 1px solid #e7ecec;
    display: flex;
    flex-direction: column;
    height: 100%;
    min-width: 0;
}

.card img {
    width: 100%;
    height: 235px;
    object-fit: cover;
    display: block;
}

.card-content {
    padding: 28px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
}

.badge-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 14px;
}

.tag,
.price-badge,
.rating-badge,
.comment-badge,
.family-badge,
.booking-badge {
    display: inline-block;
    padding: 6px 12px;
    border-radius: 999px;
    font-size: 0.84rem;
    font-weight: bold;
}

.tag {
    background-color: #e0f4f1;
    color: #005f73;
}

.family-badge {
    background: #fff4d6;
    color: #9a6700;
}

.booking-badge {
    background: #edf2f7;
    color: #334155;
}

.price-free {
    background: #e8f7e8;
    color: #256029;
}

.price-paid {
    background: #e8f0fe;
    color: #1d4ed8;
}

.price-premium {
    background: #fdeaea;
    color: #b42318;
}

.rating-badge {
    background: #fff4d6;
    color: #9a6700;
    letter-spacing: 1px;
}

.comment-badge {
    background: #edf2f7;
    color: #334155;
}

.card h3 {
    color: #005f73;
    font-size: 1.45rem;
    margin-bottom: 10px;
    line-height: 1.25;
}

.meta {
    color: #6b7280;
    font-size: 0.95rem;
    margin-bottom: 12px;
}

.card p {
    color: #334155;
    margin-bottom: 12px;
    line-height: 1.72;
}

.description-text {
    max-height: 260px;
    overflow-y: auto;
    padding-right: 8px;
}

.star-display {
    color: #ee9b00;
    font-weight: bold;
    font-size: 1.25rem;
    margin-bottom: 10px;
    letter-spacing: 2px;
}

.comments-section {
    background: #f8fafc;
    border-left: 4px solid #0a9396;
    border-radius: 12px;
    padding: 14px;
    margin: 16px 0 14px;
}

.comments-header {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    align-items: center;
    margin-bottom: 8px;
}

.comments-header h4 {
    color: #005f73;
    font-size: 1rem;
}

.comments-count-small {
    font-size: 0.78rem;
    color: #526170;
    background: white;
    border: 1px solid #e7ecec;
    padding: 4px 8px;
    border-radius: 999px;
}

.comments-scroll {
    max-height: 155px;
    overflow-y: auto;
    padding-right: 6px;
}

.single-comment {
    background: white;
    border-radius: 9px;
    padding: 9px 10px;
    margin-bottom: 8px;
    border: 1px solid #e7ecec;
    font-size: 0.86rem;
    line-height: 1.4;
}

.comment-topline {
    display: flex;
    justify-content: space-between;
    gap: 8px;
    align-items: center;
    margin-bottom: 3px;
}

.single-comment strong {
    color: #005f73;
    font-size: 0.86rem;
}

.comment-stars {
    color: #ee9b00;
    font-size: 0.8rem;
    white-space: nowrap;
    letter-spacing: 0.5px;
}

.no-comments {
    color: #526170;
    font-size: 0.9rem;
    background: white;
    padding: 10px;
    border-radius: 8px;
    border: 1px solid #e7ecec;
}

.comment-form {
    background: #f7f4ed;
    border-radius: 12px;
    padding: 14px;
    margin-bottom: 14px;
}

.comment-form h4 {
    color: #005f73;
    margin-bottom: 6px;
    font-size: 1rem;
}

.clickable-stars {
    display: flex;
    flex-direction: row-reverse;
    justify-content: flex-end;
    gap: 4px;
    margin: 4px 0 8px;
}

.clickable-stars input {
    display: none;
}

.clickable-stars label {
    font-size: 1.75rem;
    color: #cbd5e1;
    cursor: pointer;
    transition: 0.15s ease;
    line-height: 1;
}

.clickable-stars input:checked ~ label,
.clickable-stars label:hover,
.clickable-stars label:hover ~ label {
    color: #ee9b00;
}

.comment-form textarea {
    width: 100%;
    min-height: 70px;
    padding: 10px;
    border: 1px solid #cfd8dc;
    border-radius: 8px;
    resize: vertical;
    margin: 6px 0 8px;
    font-size: 0.92rem;
}

.comment-form .button {
    min-height: 36px;
    padding: 8px 12px;
    font-size: 0.88rem;
}

.guest-lock {
    background: #fff7e6;
    border-left: 4px solid #ee9b00;
    border-radius: 12px;
    padding: 12px;
    margin: 12px 0;
    color: #5f4b16;
    font-size: 0.9rem;
}

.button-row {
    margin-top: auto;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    padding-top: 12px;
}

.button-row form {
    display: flex;
}

.button.secondary {
    background-color: #0a9396;
}

.button.secondary:hover {
    background-color: #08787a;
}

.remove-button {
    background-color: #9b2226;
}

.remove-button:hover {
    background-color: #7a171b;
}

.admin-delete-comment {
    background: #9b2226;
    color: white;
    border: none;
    border-radius: 7px;
    padding: 5px 8px;
    font-size: 0.72rem;
    font-weight: bold;
    cursor: pointer;
    margin-top: 6px;
}

.admin-delete-comment:hover {
    background: #7a171b;
}

.admin-comment-actions {
    display: flex;
    justify-content: flex-end;
}

.travel-planner {
    background: white;
    padding: 26px;
    border-radius: 20px;
    box-shadow: 0 8px 20px rgba(0, 95, 115, 0.10);
    border: 1px solid #e7ecec;
    margin: 45px 0 35px;
}

.travel-planner h2 {
    color: #005f73;
    margin-bottom: 10px;
}

.travel-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 14px;
    margin-top: 18px;
}

.travel-grid select {
    width: 100%;
    padding: 12px;
    border: 1px solid #cfd8dc;
    border-radius: 10px;
    font-size: 1rem;
}

.travel-result {
    display: none;
    margin-top: 22px;
    background: #f8fafc;
    border-radius: 16px;
    padding: 18px;
    border-left: 5px solid #0a9396;
}

.travel-result h3 {
    color: #005f73;
    margin-bottom: 10px;
}

.travel-links {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 14px;
}

.map-section {
    margin-top: 60px;
}

.map-wrapper {
    background: white;
    border-radius: 18px;
    padding: 22px;
    box-shadow: 0 8px 20px rgba(0, 95, 115, 0.10);
    border: 1px solid #e7ecec;
}

#leafletMap {
    width: 100%;
    height: 560px;
    border-radius: 14px;
}

.map-note {
    margin-top: 14px;
    color: #526170;
    text-align: center;
}

.no-results {
    display: none;
    text-align: center;
    background: white;
    border-radius: 18px;
    padding: 30px;
    margin-top: 16px;
    color: #526170;
    box-shadow: 0 8px 20px rgba(0, 95, 115, 0.10);
}

.section-divider {
    margin: 70px 0 35px;
    border-top: 2px solid #e7ecec;
}

footer {
    background-color: #005f73;
    color: white;
    text-align: center;
    padding: 26px;
    margin-top: 70px;
}

@media (max-width: 1100px) {
    .filter-bar {
        grid-template-columns: 1fr 1fr;
    }
}

@media (max-width: 900px) {
    .hero,
    .highlight-banner,
    .travel-grid,
    .card-grid {
        grid-template-columns: 1fr;
    }

    .hero h1 {
        font-size: 2.5rem;
    }

    .flash-message {
        align-items: flex-start;
        flex-direction: column;
    }
}

@media (max-width: 650px) {
    .filter-bar {
        grid-template-columns: 1fr;
    }

    .card-content {
        padding: 22px;
    }
}
</style>
</head>

<body>

<header>
    <nav>
		<a href="/home">Home</a>
		<a href="/locations" class="active-link">Cultural Experiences</a>
		
		
		<a href="/library">My Library</a>
		{% if user_profile == "Tourist" or user_profile == "Admin" %}
			
			<a href="/day-planner">Day Planner</a>
		{% endif %}

		{% if user_profile == "Admin" %}
			<a href="/admin">Admin</a>
		{% endif %}

		<a href="/logout">Logout</a>
	</nav>
	
    <section class="hero">
        <div>
            <h1>Explore Brisbane cultural experiences</h1>
            <p>Discover creative events, museums, galleries, performances, family-friendly places and other featured Brisbane activities.</p>

            <div class="hero-buttons">
                <a href="#cultural-section" class="btn-primary">Cultural experiences</a>
                <a href="#activities-section" class="btn-secondary">Other activities</a>
                <a href="#map-section" class="btn-secondary">View map</a>

                {% if not is_guest %}
                    <a href="/library" class="btn-primary">My Library</a>
                {% else %}
                    <a href="/register" class="btn-primary">Create account to save</a>
                {% endif %}
            </div>
        </div>

        <div class="hero-panel">
            <h2>Page features</h2>
            <ul>
                <li>Cultural experiences listed first</li>
                <li>Family-friendly filters</li>
                <li>Other featured activities underneath</li>
                <li>Map and travel links</li>
                {% if not is_guest %}
                    <li>Save, comment and rate</li>
                {% else %}
                    <li>Limited users can browse only</li>
                {% endif %}
            </ul>
        </div>
    </section>
</header>

{% with messages = get_flashed_messages(with_categories=true) %}
    {% if messages %}
        <div class="flash-wrapper">
            {% for category, message in messages %}
                <div class="flash-message flash-{{ category }}">
                    <span>{{ message }}</span>
                    <div class="flash-actions">
                        {% if not is_guest %}
                            <a class="flash-link" href="/library">View Library</a>
                        {% else %}
                            <a class="flash-link" href="/register">Create Account</a>
                        {% endif %}
                        <button class="flash-ok" type="button" onclick="this.closest('.flash-message').remove()">OK</button>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endwith %}

<main class="container">

    {% if user_profile == "Guest" %}
        <div class="role-notice">
            <strong>Guest mode:</strong> You can browse cultural experiences, view the map and use travel links. Create an account to save favourites, comment, rate, use My Library or access the Day Planner.
        </div>
    {% elif user_profile == "Tourist" %}
        <div class="role-notice">
            <strong>Tourist mode:</strong> Use filters for free, family-friendly, highly rated and city-friendly cultural experiences.
        </div>
    {% elif user_profile == "Local" %}
        <div class="role-notice">
            <strong>Local mode:</strong> You can browse events and community activities, but saving, comments, My Library and Day Planner are restricted in this prototype.
        </div>
    {% elif user_profile == "Admin" %}
        <div class="role-notice">
            <strong>Admin mode:</strong> Use the Admin dashboard to manage users, cultural experiences, activities and comments.
        </div>
    {% endif %}

    <section class="highlight-banner">
        <div>
            <h2>Culture first, activities second</h2>
            <p>This page focuses on Brisbane cultural experiences first, then includes other featured activities underneath. The cards now use a two-column layout so the content has more room.</p>
        </div>

        <div class="highlight-box">
            <h3>{{ cultural_experiences|length }} cultural experiences</h3>
            <p>{{ activities|length }} other featured activities</p>
        </div>
    </section>

    <section id="cultural-section">
        <div class="section-header">
            <h2>Featured cultural experiences</h2>
            <p>Museums, galleries, performances, creative venues, markets and family-friendly cultural options.</p>
        </div>

        <div class="filter-bar">
            <input type="text" id="culturalSearchInput" placeholder="Search cultural experience, suburb or tag">

            <select id="culturalCategoryFilter">
                <option value="all">All cultural categories</option>
                {% for category in cultural_categories %}
                    <option value="{{ category|lower }}">{{ category }}</option>
                {% endfor %}
            </select>

            <select id="culturalPriceFilter">
                <option value="all">All prices</option>
                <option value="free">Free</option>
                <option value="paid">Paid</option>
                <option value="premium">Premium</option>
            </select>

            <select id="culturalFamilyFilter">
                <option value="all">All activity types</option>
                <option value="yes">Family friendly only</option>
            </select>

            <select id="culturalBookingFilter">
                <option value="all">All booking types</option>
                <option value="no">No booking required</option>
                <option value="yes">Booking required</option>
                <option value="sometimes">Sometimes</option>
            </select>

            <button type="button" class="btn-outline" id="resetCulturalFilters">Reset</button>
        </div>

        <div class="results-bar">
            <p id="culturalResultsCount">Showing all cultural experiences</p>
            <p>Tip: try “museum”, “market”, “family”, “free” or “performance”.</p>
        </div>

        <div class="card-grid" id="culturalGrid">
            {% for item in cultural_experiences %}

                {% if cultural_review_data and item.cultural_id in cultural_review_data %}
                    {% set display_rating = cultural_review_data[item.cultural_id].average %}
                    {% set review_count = cultural_review_data[item.cultural_id].count %}
                    {% set comments = cultural_review_data[item.cultural_id].comments %}
                {% else %}
                    {% set display_rating = item.star_rating or 0 %}
                    {% set review_count = 0 %}
                    {% set comments = [] %}
                {% endif %}

                {% set rounded_rating = display_rating|round(0, 'floor')|int %}

                <div class="card cultural-card"
                     data-name="{{ (item.name or '')|lower }}"
                     data-suburb="{{ (item.suburb or '')|lower }}"
                     data-category="{{ (item.category or '')|lower }}"
                     data-price="{{ (item.price_range or '')|lower }}"
                     data-family="{{ (item.family_friendly or '')|lower }}"
                     data-booking="{{ (item.booking_required or '')|lower }}"
                     data-tag="{{ (item.cultural_tag or '')|lower }}"
                     data-lat="{{ item.latitude }}"
                     data-lng="{{ item.longitude }}"
                     data-id="{{ item.cultural_id }}"
                     data-title="{{ item.name }}">

                    <img src="{{ item.image_url }}" alt="{{ item.name }}">

                    <div class="card-content">
                        <div class="badge-row">
                            <span class="tag">{{ item.cultural_tag }}</span>
                            <span class="booking-badge">{{ item.event_type }}</span>

                            {% if item.family_friendly == "Yes" %}
                                <span class="family-badge">Family friendly</span>
                            {% endif %}

                            {% if item.price_range == 'Free' %}
                                <span class="price-badge price-free">Free</span>
                            {% elif item.price_range == 'Premium' %}
                                <span class="price-badge price-premium">Premium</span>
                            {% else %}
                                <span class="price-badge price-paid">{{ item.price_range }}</span>
                            {% endif %}

                            <span class="comment-badge">{{ review_count }} comment{% if review_count != 1 %}s{% endif %}</span>
                        </div>

                        <h3>{{ item.name }}</h3>
                        <p class="meta">{{ item.category }} | {{ item.suburb }} | Booking: {{ item.booking_required }}</p>

                        <div class="star-display">
                            {% for i in range(rounded_rating) %}★{% endfor %}
                            {% for i in range(5 - rounded_rating) %}☆{% endfor %}
                        </div>

                        <div class="description-text">
                            <p>{{ item.description }}</p>
                        </div>

                        <div class="comments-section">
                            <div class="comments-header">
                                <h4>Visitor comments</h4>
                                <span class="comments-count-small">{{ review_count }} total</span>
                            </div>

                            <div class="comments-scroll">
                                {% if comments %}
                                    {% for comment in comments %}
                                        <div class="single-comment">
                                            <div class="comment-topline">
                                                <strong>{{ comment.username }}</strong>
                                                <span class="comment-stars">
                                                    {% for i in range(comment.rating) %}★{% endfor %}
                                                    {% for i in range(5 - comment.rating) %}☆{% endfor %}
                                                </span>
                                            </div>
                                            <p>{{ comment.comment }}</p>
                                            {% if user_profile == "Admin" %}
                                                <div class="admin-comment-actions">
                                                    <form method="POST" action="{{ url_for('admin_delete_cultural_review', cultural_review_id=comment.cultural_review_id) }}">
                                                        <button class="admin-delete-comment" type="submit" onclick="return confirm('Delete this comment?');">Delete comment</button>
                                                    </form>
                                                </div>
                                            {% endif %}
                                        </div>
                                    {% endfor %}
                                {% else %}
                                    <p class="no-comments">
                                        No comments yet.
                                        {% if not is_guest %}
                                            Be the first to add one below.
                                        {% else %}
                                            Create an account to add comments.
                                        {% endif %}
                                    </p>
                                {% endif %}
                            </div>
                        </div>

                        {% if not is_guest %}
                            <form class="comment-form" method="POST" action="{{ url_for('add_cultural_review', cultural_id=item.cultural_id) }}">
                                <h4>Add a comment</h4>

                                <div class="clickable-stars">
                                    <input type="radio" id="cstar5-{{ item.cultural_id }}" name="rating" value="5" checked>
                                    <label for="cstar5-{{ item.cultural_id }}">★</label>
                                    <input type="radio" id="cstar4-{{ item.cultural_id }}" name="rating" value="4">
                                    <label for="cstar4-{{ item.cultural_id }}">★</label>
                                    <input type="radio" id="cstar3-{{ item.cultural_id }}" name="rating" value="3">
                                    <label for="cstar3-{{ item.cultural_id }}">★</label>
                                    <input type="radio" id="cstar2-{{ item.cultural_id }}" name="rating" value="2">
                                    <label for="cstar2-{{ item.cultural_id }}">★</label>
                                    <input type="radio" id="cstar1-{{ item.cultural_id }}" name="rating" value="1">
                                    <label for="cstar1-{{ item.cultural_id }}">★</label>
                                </div>

                                <textarea name="comment" placeholder="Write your comment..." required></textarea>
                                <button class="button" type="submit">Post comment</button>
                            </form>
                        {% else %}
                            <div class="guest-lock">
                                Limited users can view comments but cannot post comments or ratings.
                                <a href="/register">Create an account</a> to join the conversation.
                            </div>
                        {% endif %}

                        <div class="button-row">
                            {% if item.website_link %}
                                <a class="button" href="{{ item.website_link }}" target="_blank">Learn more</a>
                            {% endif %}

                            {% if not is_guest %}
                                {% if item.cultural_id in cultural_favourite_ids %}
                                    <form method="POST" action="{{ url_for('remove_cultural_favourite', cultural_id=item.cultural_id) }}">
                                        <button class="button remove-button" type="submit">Remove ★</button>
                                    </form>
                                {% else %}
                                    <form method="POST" action="{{ url_for('add_cultural_favourite', cultural_id=item.cultural_id) }}">
                                        <button class="button" type="submit">Save ★</button>
                                    </form>
                                {% endif %}
                            {% else %}
                                <a class="button" href="/register">Create account to save</a>
                            {% endif %}

                            <button class="button secondary" type="button" data-name="{{ item.name }}" data-lat="{{ item.latitude }}" data-lng="{{ item.longitude }}" onclick="planDirectionsFromButton(this)">Directions</button>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>

        <div class="no-results" id="culturalNoResults">
            <h3>No cultural experiences found</h3>
            <p>Try a different cultural search or filter.</p>
        </div>
    </section>

    <div class="section-divider"></div>

    <section id="activities-section">
        <div class="section-header">
            <h2>Other featured Brisbane activities</h2>
            <p>These are extra visitor activities that support day planning, tourism and Olympic visitor experiences.</p>
        </div>

        <div class="filter-bar">
            <input type="text" id="activitySearchInput" placeholder="Search activity, suburb, category or cultural tag">

            <select id="activityCategoryFilter">
                <option value="all">All activity categories</option>
                {% for category in activity_categories %}
                    <option value="{{ category|lower }}">{{ category }}</option>
                {% endfor %}
            </select>

            <select id="activityPriceFilter">
                <option value="all">All prices</option>
                <option value="free">Free</option>
                <option value="paid">Paid</option>
                <option value="premium">Premium</option>
            </select>

            <select id="activityFamilyFilter">
                <option value="all">All activity types</option>
                <option value="family friendly">Family friendly only</option>
            </select>

            <select id="activityRatingFilter">
                <option value="0">Any rating</option>
                <option value="5">5 stars only</option>
                <option value="4">4+ stars</option>
                <option value="3">3+ stars</option>
                <option value="2">2+ stars</option>
            </select>

            <button type="button" class="btn-outline" id="resetActivityFilters">Reset</button>
        </div>

        <div class="results-bar">
            <p id="activityResultsCount">Showing all activities</p>
            <p>Tip: use this section for attractions, outdoor activities and food experiences.</p>
        </div>

        <div class="card-grid" id="activityGrid">
            {% for activity in activities %}

                {% if review_data and activity.activity_id in review_data %}
                    {% set display_rating = review_data[activity.activity_id].average %}
                    {% set review_count = review_data[activity.activity_id].count %}
                    {% set comments = review_data[activity.activity_id].comments %}
                {% else %}
                    {% set display_rating = activity.star_rating or 0 %}
                    {% set review_count = 0 %}
                    {% set comments = [] %}
                {% endif %}

                {% set rounded_rating = display_rating|round(0, 'floor')|int %}

                {% if activity.price_range == "Free" %}
                    {% set price_value = 0 %}
                {% elif activity.price_range == "Paid" %}
                    {% set price_value = 1 %}
                {% elif activity.price_range == "Premium" %}
                    {% set price_value = 2 %}
                {% else %}
                    {% set price_value = 3 %}
                {% endif %}

                <div class="card activity-card"
                     data-name="{{ (activity.name or '')|lower }}"
                     data-suburb="{{ (activity.suburb or '')|lower }}"
                     data-category="{{ (activity.category or '')|lower }}"
                     data-price="{{ (activity.price_range or '')|lower }}"
                     data-family="{{ (activity.cultural_tag or '')|lower }}"
                     data-tag="{{ (activity.cultural_tag or '')|lower }}"
                     data-price-value="{{ price_value }}"
                     data-rating="{{ display_rating }}"
                     data-lat="{{ activity.latitude }}"
                     data-lng="{{ activity.longitude }}"
                     data-id="{{ activity.activity_id }}"
                     data-title="{{ activity.name }}">

                    <img src="{{ activity.image_url }}" alt="{{ activity.name }}">

                    <div class="card-content">
                        <div class="badge-row">
                            <span class="tag">{{ activity.cultural_tag }}</span>

                            {% if activity.cultural_tag and activity.cultural_tag|lower == "family friendly" %}
                                <span class="family-badge">Family friendly</span>
                            {% endif %}

                            {% if activity.price_range == 'Free' %}
                                <span class="price-badge price-free">Free</span>
                            {% elif activity.price_range == 'Premium' %}
                                <span class="price-badge price-premium">Premium</span>
                            {% else %}
                                <span class="price-badge price-paid">{{ activity.price_range }}</span>
                            {% endif %}

                            <span class="rating-badge">
                                {% for i in range(rounded_rating) %}★{% endfor %}
                                {% for i in range(5 - rounded_rating) %}☆{% endfor %}
                            </span>

                            <span class="comment-badge">{{ review_count }} comment{% if review_count != 1 %}s{% endif %}</span>
                        </div>

                        <h3>{{ activity.name }}</h3>
                        <p class="meta">{{ activity.category }} | {{ activity.suburb }}</p>

                        <div class="star-display">
                            {% for i in range(rounded_rating) %}★{% endfor %}
                            {% for i in range(5 - rounded_rating) %}☆{% endfor %}
                        </div>

                        <div class="description-text">
                            <p>{{ activity.description }}</p>
                        </div>

                        <div class="comments-section">
                            <div class="comments-header">
                                <h4>Visitor comments</h4>
                                <span class="comments-count-small">{{ review_count }} total</span>
                            </div>

                            <div class="comments-scroll">
                                {% if comments %}
                                    {% for comment in comments %}
                                        <div class="single-comment">
                                            <div class="comment-topline">
                                                <strong>{{ comment.username }}</strong>
                                                <span class="comment-stars">
                                                    {% for i in range(comment.rating) %}★{% endfor %}
                                                    {% for i in range(5 - comment.rating) %}☆{% endfor %}
                                                </span>
                                            </div>
                                            <p>{{ comment.comment }}</p>
                                        </div>
                                    {% endfor %}
                                {% else %}
                                    <p class="no-comments">No comments yet.</p>
                                {% endif %}
                            </div>
                        </div>

                        {% if not is_guest %}
                            <form class="comment-form" method="POST" action="{{ url_for('add_comment', activity_id=activity.activity_id) }}">
                                <h4>Add a comment</h4>

                                <div class="clickable-stars">
                                    <input type="radio" id="star5-{{ activity.activity_id }}" name="rating" value="5" checked>
                                    <label for="star5-{{ activity.activity_id }}">★</label>
                                    <input type="radio" id="star4-{{ activity.activity_id }}" name="rating" value="4">
                                    <label for="star4-{{ activity.activity_id }}">★</label>
                                    <input type="radio" id="star3-{{ activity.activity_id }}" name="rating" value="3">
                                    <label for="star3-{{ activity.activity_id }}">★</label>
                                    <input type="radio" id="star2-{{ activity.activity_id }}" name="rating" value="2">
                                    <label for="star2-{{ activity.activity_id }}">★</label>
                                    <input type="radio" id="star1-{{ activity.activity_id }}" name="rating" value="1">
                                    <label for="star1-{{ activity.activity_id }}">★</label>
                                </div>

                                <textarea name="comment" placeholder="Write your comment..." required></textarea>
                                <button class="button" type="submit">Post comment</button>
                            </form>
                        {% endif %}

                        <div class="button-row">
                            {% if activity.website_link %}
                                <a class="button" href="{{ activity.website_link }}" target="_blank">Learn more</a>
                            {% endif %}

                            {% if not is_guest %}
                                {% if activity.activity_id in favourite_ids %}
                                    <form method="POST" action="{{ url_for('remove_favourite', activity_id=activity.activity_id) }}">
                                        <button class="button remove-button" type="submit">Remove ★</button>
                                    </form>
                                {% else %}
                                    <form method="POST" action="{{ url_for('add_favourite', activity_id=activity.activity_id) }}">
                                        <button class="button" type="submit">Save ★</button>
                                    </form>
                                {% endif %}
                            {% else %}
                                <a class="button" href="/register">Create account to save</a>
                            {% endif %}

                            <button class="button secondary" type="button" data-name="{{ activity.name }}" data-lat="{{ activity.latitude }}" data-lng="{{ activity.longitude }}" onclick="planDirectionsFromButton(this)">Directions</button>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>

        <div class="no-results" id="activityNoResults">
            <h3>No activities found</h3>
            <p>Try a different activity search or filter.</p>
        </div>
    </section>

    <section class="travel-planner">
        <h2>Travel planner</h2>
        <p>Choose any cultural experience or featured activity. The selected place will appear on the map below, with Google Maps and Translink options.</p>

        <div class="travel-grid">
            <select id="travelDestination">
                <option value="">Choose a destination...</option>

                {% for item in cultural_experiences %}
                    <option data-name="{{ item.name }}" data-lat="{{ item.latitude }}" data-lng="{{ item.longitude }}">{{ item.name }} — {{ item.suburb }}</option>
                {% endfor %}

                {% for activity in activities %}
                    <option data-name="{{ activity.name }}" data-lat="{{ activity.latitude }}" data-lng="{{ activity.longitude }}">{{ activity.name }} — {{ activity.suburb }}</option>
                {% endfor %}
            </select>

            <button class="button" type="button" onclick="loadTravelPlanFromSelect()">Plan travel</button>
        </div>

        <div class="travel-result" id="travelResult">
            <h3 id="travelTitle">Travel plan</h3>
            <p id="travelDetails"></p>

            <div class="travel-links">
                <a class="button" id="googleDirectionsLink" target="_blank">Open Google directions</a>
                <a class="button secondary" id="translinkJourneyLink" target="_blank">Open Translink journey planner</a>
            </div>
        </div>
    </section>

    <section id="map-section" class="map-section">
        <div class="section-header">
            <h2>Interactive Brisbane map</h2>
            <p>Press Directions on a card to show it here. If location access is allowed, a guide line from your current location will appear.</p>
        </div>

        <div class="map-wrapper">
            <div id="leafletMap"></div>
            <p class="map-note" id="mapNote">The map updates to match visible locations above.</p>
        </div>
    </section>

</main>

<footer>
    <p>&copy; 2026 Brisbane Olympic Visitor Guide</p>
</footer>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
const map = L.map("leafletMap").setView([-27.4698, 153.0251], 11);

L.tileLayer("https://{s}.tile.openstreetmap.fr/hot/{z}/{x}/{y}.png", {
    maxZoom: 19,
    attribution: "&copy; OpenStreetMap contributors"
}).addTo(map);

let userMarker = null;
let routeLine = null;
let selectedDestinationMarker = null;

const destinationIcon = L.icon({
    iconUrl: "https://cdn-icons-png.flaticon.com/512/684/684908.png",
    iconSize: [34, 34],
    iconAnchor: [17, 34],
    popupAnchor: [0, -34]
});

const userIcon = L.icon({
    iconUrl: "https://cdn-icons-png.flaticon.com/512/149/149060.png",
    iconSize: [30, 30],
    iconAnchor: [15, 30],
    popupAnchor: [0, -30]
});

const allCards = Array.from(document.querySelectorAll(".cultural-card, .activity-card"));
const markers = {};

allCards.forEach(card => {
    const lat = parseFloat(card.dataset.lat);
    const lng = parseFloat(card.dataset.lng);
    const title = card.dataset.title;

    if (!Number.isNaN(lat) && !Number.isNaN(lng)) {
        const marker = L.marker([lat, lng]).addTo(map);
        marker.bindPopup(`<strong>${title}</strong>`);
        markers[title] = marker;
    }
});

function loadTravelPlanFromSelect() {
    const select = document.getElementById("travelDestination");
    const option = select.options[select.selectedIndex];

    if (!option || !option.dataset.name) {
        alert("Please choose a destination first.");
        return;
    }

    const name = option.dataset.name;
    const lat = parseFloat(option.dataset.lat);
    const lng = parseFloat(option.dataset.lng);

    planDirections(name, lat, lng);
}

function planDirectionsFromButton(button) {
    const name = button.dataset.name;
    const lat = parseFloat(button.dataset.lat);
    const lng = parseFloat(button.dataset.lng);

    planDirections(name, lat, lng);
}

function planDirections(name, lat, lng) {
    const googleUrl = `https://www.google.com/maps/dir/?api=1&destination=${lat},${lng}&travelmode=transit`;
    const translinkUrl = "https://jp.translink.com.au/plan-your-journey/journey-planner";

    document.getElementById("travelResult").style.display = "block";
    document.getElementById("travelTitle").textContent = "Travel to " + name;
    document.getElementById("travelDetails").textContent =
        "Use public transport where possible. Open Google Maps Transit or Translink to check live journey options.";

    document.getElementById("googleDirectionsLink").href = googleUrl;
    document.getElementById("translinkJourneyLink").href = translinkUrl;

    showDestinationOnMap(name, lat, lng);
}

function showDestinationOnMap(name, lat, lng) {
    const destinationLatLng = [lat, lng];

    if (selectedDestinationMarker) {
        map.removeLayer(selectedDestinationMarker);
    }

    if (routeLine) {
        map.removeLayer(routeLine);
        routeLine = null;
    }

    selectedDestinationMarker = L.marker(destinationLatLng, { icon: destinationIcon })
        .addTo(map)
        .bindPopup(`<strong>${name}</strong><br>Selected destination`)
        .openPopup();

    map.setView(destinationLatLng, 14);

    document.getElementById("map-section").scrollIntoView({
        behavior: "smooth",
        block: "start"
    });

    document.getElementById("mapNote").textContent =
        "Showing selected destination. Allow location access to show a guide line from your current position.";

    if (navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(
            position => {
                const userLatLng = [position.coords.latitude, position.coords.longitude];

                if (userMarker) {
                    map.removeLayer(userMarker);
                }

                userMarker = L.marker(userLatLng, { icon: userIcon })
                    .addTo(map)
                    .bindPopup("Your current location");

                routeLine = L.polyline([userLatLng, destinationLatLng], {
                    weight: 5,
                    opacity: 0.8,
                    dashArray: "10, 10"
                }).addTo(map);

                map.fitBounds([userLatLng, destinationLatLng], { padding: [60, 60] });

                document.getElementById("mapNote").textContent =
                    "Guide line shown from your current location to the selected destination. Open Google Maps Transit for exact routing.";
            },
            () => {
                document.getElementById("mapNote").textContent =
                    "Destination shown. Location access was not allowed.";
            }
        );
    }
}

function applyCulturalFilters() {
    const searchValue = document.getElementById("culturalSearchInput").value.trim().toLowerCase();
    const categoryValue = document.getElementById("culturalCategoryFilter").value.toLowerCase();
    const priceValue = document.getElementById("culturalPriceFilter").value.toLowerCase();
    const familyValue = document.getElementById("culturalFamilyFilter").value.toLowerCase();
    const bookingValue = document.getElementById("culturalBookingFilter").value.toLowerCase();

    const cards = Array.from(document.querySelectorAll(".cultural-card"));
    let visible = 0;

    cards.forEach(card => {
        const matchesSearch =
            searchValue === "" ||
            card.dataset.name.includes(searchValue) ||
            card.dataset.suburb.includes(searchValue) ||
            card.dataset.category.includes(searchValue) ||
            card.dataset.tag.includes(searchValue);

        const matchesCategory = categoryValue === "all" || card.dataset.category === categoryValue;
        const matchesPrice = priceValue === "all" || card.dataset.price === priceValue;
        const matchesFamily = familyValue === "all" || card.dataset.family === "yes";
        const matchesBooking = bookingValue === "all" || card.dataset.booking === bookingValue;

        if (matchesSearch && matchesCategory && matchesPrice && matchesFamily && matchesBooking) {
            card.style.display = "flex";
            visible++;
        } else {
            card.style.display = "none";
        }
    });

    document.getElementById("culturalResultsCount").textContent =
        "Showing " + visible + " cultural experience" + (visible === 1 ? "" : "s");

    document.getElementById("culturalNoResults").style.display = visible === 0 ? "block" : "none";
}

function applyActivityFilters() {
    const searchValue = document.getElementById("activitySearchInput").value.trim().toLowerCase();
    const categoryValue = document.getElementById("activityCategoryFilter").value.toLowerCase();
    const priceValue = document.getElementById("activityPriceFilter").value.toLowerCase();
    const familyValue = document.getElementById("activityFamilyFilter").value.toLowerCase();
    const minimumRating = parseFloat(document.getElementById("activityRatingFilter").value);

    const cards = Array.from(document.querySelectorAll(".activity-card"));
    let visible = 0;

    cards.forEach(card => {
        const rating = parseFloat(card.dataset.rating || 0);

        const matchesSearch =
            searchValue === "" ||
            card.dataset.name.includes(searchValue) ||
            card.dataset.suburb.includes(searchValue) ||
            card.dataset.category.includes(searchValue) ||
            card.dataset.tag.includes(searchValue);

        const matchesCategory = categoryValue === "all" || card.dataset.category === categoryValue;
        const matchesPrice = priceValue === "all" || card.dataset.price === priceValue;
        const matchesFamily = familyValue === "all" || card.dataset.family.includes("family friendly");
        const matchesRating = rating >= minimumRating;

        if (matchesSearch && matchesCategory && matchesPrice && matchesFamily && matchesRating) {
            card.style.display = "flex";
            visible++;
        } else {
            card.style.display = "none";
        }
    });

    document.getElementById("activityResultsCount").textContent =
        "Showing " + visible + " activit" + (visible === 1 ? "y" : "ies");

    document.getElementById("activityNoResults").style.display = visible === 0 ? "block" : "none";
}

function connectFilterEvents() {
    document.getElementById("culturalSearchInput").addEventListener("input", applyCulturalFilters);
    document.getElementById("culturalCategoryFilter").addEventListener("change", applyCulturalFilters);
    document.getElementById("culturalPriceFilter").addEventListener("change", applyCulturalFilters);
    document.getElementById("culturalFamilyFilter").addEventListener("change", applyCulturalFilters);
    document.getElementById("culturalBookingFilter").addEventListener("change", applyCulturalFilters);

    document.getElementById("resetCulturalFilters").addEventListener("click", function () {
        document.getElementById("culturalSearchInput").value = "";
        document.getElementById("culturalCategoryFilter").value = "all";
        document.getElementById("culturalPriceFilter").value = "all";
        document.getElementById("culturalFamilyFilter").value = "all";
        document.getElementById("culturalBookingFilter").value = "all";
        applyCulturalFilters();
    });

    document.getElementById("activitySearchInput").addEventListener("input", applyActivityFilters);
    document.getElementById("activityCategoryFilter").addEventListener("change", applyActivityFilters);
    document.getElementById("activityPriceFilter").addEventListener("change", applyActivityFilters);
    document.getElementById("activityFamilyFilter").addEventListener("change", applyActivityFilters);
    document.getElementById("activityRatingFilter").addEventListener("change", applyActivityFilters);

    document.getElementById("resetActivityFilters").addEventListener("click", function () {
        document.getElementById("activitySearchInput").value = "";
        document.getElementById("activityCategoryFilter").value = "all";
        document.getElementById("activityPriceFilter").value = "all";
        document.getElementById("activityFamilyFilter").value = "all";
        document.getElementById("activityRatingFilter").value = "0";
        applyActivityFilters();
    });
}

connectFilterEvents();
applyCulturalFilters();
applyActivityFilters();

setTimeout(() => {
    map.invalidateSize();
}, 200);
</script>

</body>
</html>
