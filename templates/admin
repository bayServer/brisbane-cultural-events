<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Dashboard | Brisbane Olympic Visitor Guide</title>

<style>
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
    font-family: Arial, sans-serif;
}

body {
    background: #f6f4ef;
    color: #1f2d3d;
    line-height: 1.6;
}

header {
    background: linear-gradient(135deg, #005f73, #0a9396);
    color: white;
    padding-bottom: 45px;
}

nav {
    display: flex;
    justify-content: center;
    gap: 14px;
    padding: 18px;
    flex-wrap: wrap;
}

nav a {
    color: white;
    text-decoration: none;
    font-weight: bold;
    padding: 9px 15px;
    border-radius: 999px;
}

nav a:hover,
.active-link {
    background: #ee9b00;
}

.hero {
    width: 90%;
    max-width: 1050px;
    margin: auto;
    padding-top: 40px;
    text-align: center;
}

.hero h1 {
    font-size: 2.7rem;
    margin-bottom: 10px;
}

.hero p {
    font-size: 1.05rem;
    opacity: 0.95;
}

.container {
    width: 90%;
    max-width: 1150px;
    margin: 40px auto;
}

.flash-message {
    padding: 14px 18px;
    border-radius: 14px;
    margin-bottom: 18px;
    font-weight: bold;
}

.flash-success {
    background: #e8f7e8;
    color: #256029;
    border-left: 5px solid #2a9d8f;
}

.flash-error {
    background: #fdeaea;
    color: #9b2226;
    border-left: 5px solid #9b2226;
}

.flash-info {
    background: #e8f0fe;
    color: #1d4ed8;
    border-left: 5px solid #1d4ed8;
}

.admin-intro {
    background: white;
    padding: 24px;
    border-radius: 20px;
    box-shadow: 0 8px 20px rgba(0, 95, 115, 0.10);
    margin-bottom: 28px;
    border-left: 6px solid #ee9b00;
}

.admin-intro h2 {
    color: #005f73;
    margin-bottom: 8px;
}

.admin-intro p {
    color: #52616b;
}

.summary-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-bottom: 28px;
}

.summary-card {
    background: white;
    padding: 24px;
    border-radius: 20px;
    box-shadow: 0 8px 20px rgba(0, 95, 115, 0.10);
    border: 1px solid #e7ecec;
}

.summary-card span {
    color: #52616b;
    font-weight: bold;
    font-size: 0.95rem;
}

.summary-card strong {
    display: block;
    font-size: 2.3rem;
    color: #005f73;
    margin-top: 6px;
}

.action-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 22px;
    margin-bottom: 30px;
}

.panel {
    background: white;
    padding: 26px;
    border-radius: 22px;
    box-shadow: 0 8px 20px rgba(0, 95, 115, 0.10);
    border: 1px solid #e7ecec;
    margin-bottom: 30px;
}

.panel h2 {
    color: #005f73;
    margin-bottom: 8px;
}

.panel p {
    margin-bottom: 18px;
    color: #52616b;
}

.api-box {
    background: #f0fbfa;
    border: 1px solid #cdecea;
}

.manual-box {
    background: #fffdf8;
    border: 1px solid #f1e1ba;
}

button {
    border: none;
    border-radius: 999px;
    padding: 12px 20px;
    font-weight: bold;
    cursor: pointer;
    font-size: 0.95rem;
}

.primary-btn {
    background: #005f73;
    color: white;
}

.primary-btn:hover {
    background: #0a9396;
}

.refresh-btn {
    background: #ee9b00;
    color: white;
}

.refresh-btn:hover {
    background: #ca7b00;
}

.delete-btn {
    background: #9b2226;
    color: white;
    padding: 9px 14px;
}

.delete-btn:hover {
    background: #7f1d1d;
}

.form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
}

.form-full {
    grid-column: 1 / -1;
}

label {
    display: block;
    font-weight: bold;
    color: #005f73;
    margin-bottom: 6px;
}

input,
select,
textarea {
    width: 100%;
    padding: 12px;
    border: 1px solid #ccd6d6;
    border-radius: 12px;
    font-size: 1rem;
    background: white;
}

textarea {
    min-height: 110px;
    resize: vertical;
}

.table-wrapper {
    overflow-x: auto;
}

table {
    width: 100%;
    border-collapse: collapse;
    min-width: 800px;
}

th,
td {
    padding: 13px;
    border-bottom: 1px solid #e7ecec;
    text-align: left;
    vertical-align: top;
}

th {
    background: #e0f4f1;
    color: #005f73;
}

.small-text {
    font-size: 0.9rem;
    color: #52616b;
}

.badge {
    padding: 6px 10px;
    border-radius: 999px;
    font-weight: bold;
    font-size: 0.85rem;
    display: inline-block;
}

.badge-api {
    background: #e8f0fe;
    color: #1d4ed8;
}

.badge-admin {
    background: #e8f7e8;
    color: #256029;
}

.badge-other {
    background: #fff7e6;
    color: #8a5a00;
}

.badge-role-admin {
    background: #fdeaea;
    color: #9b2226;
}

.badge-role-local {
    background: #e8f7e8;
    color: #256029;
}

.badge-role-tourist {
    background: #e8f0fe;
    color: #1d4ed8;
}

footer {
    background: #005f73;
    color: white;
    text-align: center;
    padding: 24px;
    margin-top: 55px;
}

@media (max-width: 900px) {
    .summary-grid,
    .action-grid,
    .form-grid {
        grid-template-columns: 1fr;
    }

    .hero h1 {
        font-size: 2.2rem;
    }
}
</style>
</head>

<body>

<header>
    <nav>
        <a href="/home">Home</a>
        <a href="/locations">Locations</a>
        <a href="/olympic-events">Olympic Events</a>
        <a href="/library">My Library</a>
        <a href="/day-planner">Day Planner</a>
        <a href="/admin" class="active-link">Admin</a>
        <a href="/logout">Logout</a>
    </nav>

    <section class="hero">
        <h1>Admin Dashboard</h1>
        <p>Manage Brisbane cultural events, API records, users and saved favourites.</p>
    </section>
</header>

<main class="container">

    {% with messages = get_flashed_messages(with_categories=true) %}
        {% if messages %}
            {% for category, message in messages %}
                <div class="flash-message flash-{{ category }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endif %}
    {% endwith %}

    <section class="admin-intro">
        <h2>Admin controls</h2>
        <p>This page is only for administrators. Use the API refresh for official Brisbane Creative Events data, or manually add an experience if you need extra test data for your prototype.</p>
    </section>

    <section class="summary-grid">
        <div class="summary-card">
            <span>Registered users</span>
            <strong>{{ total_users }}</strong>
        </div>

        <div class="summary-card">
            <span>Cultural experiences</span>
            <strong>{{ total_cultural_experiences }}</strong>
        </div>

        <div class="summary-card">
            <span>API records</span>
            <strong>{{ total_api_events }}</strong>
        </div>

        <div class="summary-card">
            <span>Activities</span>
            <strong>{{ total_activities }}</strong>
        </div>

        <div class="summary-card">
            <span>Total saves</span>
            <strong>{{ total_activity_favourites + total_cultural_favourites + total_olympic_favourites }}</strong>
        </div>

        <div class="summary-card">
            <span>Total reviews</span>
            <strong>{{ total_reviews }}</strong>
        </div>
    </section>

    <section class="panel api-box">
        <h2>Refresh official JSON API</h2>
        <p>Imports the latest Brisbane Creative Events records and stores them in the local database.</p>

        <form action="{{ url_for('admin_refresh_cultural_json') }}" method="POST">
            <button type="submit" class="refresh-btn">Refresh JSON Events</button>
        </form>
    </section>

    <section class="panel">
        <h2>Add a manual cultural experience</h2>
        <p>Use this only when an event needs to be added by an administrator instead of the API.</p>

        <form action="{{ url_for('admin_add_cultural_experience') }}" method="POST">
            <div class="form-grid">
                <div>
                    <label for="name">Experience name *</label>
                    <input type="text" id="name" name="name" placeholder="Example: Queensland Art Gallery" required>
                </div>

                <div>
                    <label for="category">Category *</label>
                    <input type="text" id="category" name="category" placeholder="Museum, Gallery, Performance" required>
                </div>

                <div>
                    <label for="suburb">Location *</label>
                    <input type="text" id="suburb" name="suburb" placeholder="South Brisbane" required>
                </div>

                <div>
                    <label for="price_range">Price</label>
                    <select id="price_range" name="price_range">
                        <option value="Free">Free</option>
                        <option value="Paid">Paid</option>
                        <option value="Premium">Premium</option>
                        <option value="Unknown">Unknown</option>
                    </select>
                </div>

                <div class="form-full">
                    <label for="description">Description *</label>
                    <textarea id="description" name="description" placeholder="Briefly describe the cultural experience." required></textarea>
                </div>

                <div>
                    <label for="website_link">Website link</label>
                    <input type="url" id="website_link" name="website_link" placeholder="https://example.com">
                </div>

                <div>
                    <label for="image_url">Image URL</label>
                    <input type="url" id="image_url" name="image_url" placeholder="https://example.com/image.jpg">
                </div>

                <div>
                    <label for="family_friendly">Family friendly</label>
                    <select id="family_friendly" name="family_friendly">
                        <option value="Unknown">Unknown</option>
                        <option value="Yes">Yes</option>
                        <option value="No">No</option>
                        <option value="Sometimes">Sometimes</option>
                    </select>
                </div>

                <div>
                    <label for="booking_required">Booking required</label>
                    <select id="booking_required" name="booking_required">
                        <option value="Unknown">Unknown</option>
                        <option value="No">No</option>
                        <option value="Yes">Yes</option>
                        <option value="Sometimes">Sometimes</option>
                    </select>
                </div>

                <div>
                    <label for="latitude">Latitude</label>
                    <input type="number" step="any" id="latitude" name="latitude" value="-27.4698">
                </div>

                <div>
                    <label for="longitude">Longitude</label>
                    <input type="number" step="any" id="longitude" name="longitude" value="153.0251">
                </div>

                <div>
                    <label for="star_rating">Star rating</label>
                    <input type="number" step="0.1" min="1" max="5" id="star_rating" name="star_rating" value="4.5">
                </div>
            </div>

            <button type="submit" class="primary-btn" style="margin-top: 18px;">Add Manual Experience</button>
        </form>
    </section>

    <section class="panel">
        <h2>Current cultural experiences</h2>
        <p>These records are stored in your database. API records and manual records are clearly labelled.</p>

        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Experience</th>
                        <th>Category</th>
                        <th>Location</th>
                        <th>Price</th>
                        <th>Source</th>
                        <th>Delete</th>
                    </tr>
                </thead>

                <tbody>
                    {% for item in all_cultural_experiences %}
                    <tr>
                        <td>{{ item.cultural_id }}</td>

                        <td>
                            <strong>{{ item.name }}</strong><br>
                            <span class="small-text">
                                {{ item.description[:120] }}{% if item.description|length > 120 %}...{% endif %}
                            </span>
                        </td>

                        <td>{{ item.category }}</td>
                        <td>{{ item.suburb }}</td>
                        <td>{{ item.price_range or "Unknown" }}</td>

                        <td>
                            {% if item.source == "JSON API" %}
                                <span class="badge badge-api">JSON API</span>
                            {% elif item.source == "Admin" %}
                                <span class="badge badge-admin">Admin</span>
                            {% else %}
                                <span class="badge badge-other">{{ item.source or "Seed" }}</span>
                            {% endif %}
                        </td>

                        <td>
                            <form action="{{ url_for('admin_delete_cultural_experience', cultural_id=item.cultural_id) }}" method="POST" onsubmit="return confirm('Delete this cultural experience and its saves/reviews?');">
                                <button type="submit" class="delete-btn">Delete</button>
                            </form>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="7">No cultural experiences have been added yet.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>

    <section class="panel">
        <h2>Registered users</h2>
        <p>This table shows the users stored in the system and their profile type.</p>

        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>User ID</th>
                        <th>Username</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                    </tr>
                </thead>

                <tbody>
                    {% for user_item in users %}
                    <tr>
                        <td>{{ user_item["userID"] }}</td>
                        <td>{{ user_item["username"] }}</td>
                        <td>{{ user_item["first_name"] }} {{ user_item["surname"] }}</td>
                        <td>{{ user_item["email"] }}</td>
                        <td>
                            {% if user_item["user_profile"] == "Admin" %}
                                <span class="badge badge-role-admin">Admin</span>
                            {% elif user_item["user_profile"] == "Local" %}
                                <span class="badge badge-role-local">Local</span>
                            {% else %}
                                <span class="badge badge-role-tourist">Tourist</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="5">No registered users found.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>

</main>

<footer>
    <p>&copy; 2026 Brisbane Olympic Visitor Guide</p>
</footer>

</body>
</html>
