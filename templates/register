<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Create Account | Brisbane Cultural Events</title>

<style>
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
    font-family: Arial, sans-serif;
}

body {
    min-height: 100vh;
    background: linear-gradient(135deg, #005f73, #0a9396, #94d2bd);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 30px;
    color: #1f2d3d;
}

.card {
    background: white;
    max-width: 540px;
    width: 100%;
    padding: 34px;
    border-radius: 18px;
    box-shadow: 0 12px 30px rgba(0,0,0,.2);
}

h1 {
    text-align: center;
    color: #005f73;
    margin-bottom: 8px;
}

.intro {
    text-align: center;
    color: #526170;
    margin-bottom: 22px;
}

.grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
}

.full {
    grid-column: 1 / -1;
}

label {
    font-weight: bold;
    color: #005f73;
    font-size: .92rem;
}

input,
select {
    width: 100%;
    padding: 12px;
    margin-top: 6px;
    border-radius: 9px;
    border: 1px solid #cfd8dc;
}

button {
    width: 100%;
    margin-top: 20px;
    padding: 13px;
    border: none;
    border-radius: 10px;
    background: #ee9b00;
    color: white;
    font-weight: bold;
    cursor: pointer;
}

button:hover {
    background: #ca6702;
}

.error {
    background: #fdeaea;
    color: #9b2226;
    border-left: 5px solid #9b2226;
    padding: 12px;
    border-radius: 10px;
    margin-bottom: 14px;
    font-weight: bold;
}

.note {
    background: #e0f4f1;
    border-left: 5px solid #0a9396;
    padding: 12px;
    border-radius: 10px;
    margin-top: 10px;
    color: #005f73;
    font-size: .9rem;
}

.login {
    text-align: center;
    margin-top: 18px;
}

.login a {
    color: #005f73;
    font-weight: bold;
    text-decoration: none;
}

@media(max-width:600px) {
    .grid {
        grid-template-columns: 1fr;
    }
}
</style>
</head>

<body>

<div class="card">
    <h1>Create Account</h1>
    <p class="intro">Choose Tourist or Local. Admin access is manually assigned by the website owner.</p>

    {% if error %}
        <div class="error">{{ error }}</div>
    {% endif %}

    <form method="POST" action="{{ url_for('register') }}">
        <div class="grid">
            <div class="full">
                <label>Username *</label>
                <input type="text" name="username" required>
            </div>

            <div>
                <label>First name</label>
                <input type="text" name="first_name">
            </div>

            <div>
                <label>Surname</label>
                <input type="text" name="surname">
            </div>

            <div class="full">
                <label>Email</label>
                <input type="email" name="email">
            </div>

            <div>
                <label>Phone number</label>
                <input type="text" name="phone_number">
            </div>

            <div>
                <label>Date of birth</label>
                <input type="date" name="dob">
            </div>

            <div class="full">
                <label>User type *</label>
                <select name="user_profile" required>
                    <option value="Tourist">Tourist</option>
                    <option value="Local">Local</option>
					<option value="Admin">Admin</option>
                </select>

                <div class="full">
					<label>Admin code</label>
					<input type="text" name="admin_code" placeholder="Leave blank unless you are the website admin">

					<div class="note">
						Leave this blank for a normal Tourist account. Admin access is only for authorised users.
					</div>
				</div>

            <div>
                <label>Password *</label>
                <input type="password" name="password" required>
            </div>

            <div>
                <label>Confirm password *</label>
                <input type="password" name="confirm_password" required>
            </div>
        </div>

        <button type="submit">Create Account</button>
    </form>

    <p class="login">
        Already have an account? <a href="{{ url_for('login') }}">Log in</a>
    </p>
</div>

</body>
</html>
