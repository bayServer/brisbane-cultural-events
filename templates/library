<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Library | Brisbane Olympic Visitor Guide</title>

<style>
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
    font-family: Arial, sans-serif;
}

html {
    scroll-behavior: smooth;
}

body {
    background-color: #f7f4ed;
    color: #1f2d3d;
    line-height: 1.6;
}

header {
    background: linear-gradient(rgba(0, 95, 115, 0.78), rgba(10, 147, 150, 0.66)),
                url("https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1600&q=80") center/cover no-repeat;
    color: white;
    min-height: 62vh;
}

nav {
    display: flex;
    justify-content: center;
    gap: 18px;
    padding: 20px;
    background: rgba(255, 255, 255, 0.10);
    backdrop-filter: blur(6px);
    flex-wrap: wrap;
}

nav a {
    text-decoration: none;
    color: white;
    font-weight: bold;
    padding: 10px 16px;
    border-radius: 999px;
    transition: 0.2s ease;
}

nav a:hover,
.active-link {
    background-color: #ee9b00;
}

.hero {
    width: 90%;
    max-width: 1200px;
    margin: auto;
    padding: 70px 0;
    display: grid;
    grid-template-columns: 1.4fr 0.8fr;
    gap: 30px;
    align-items: center;
}

.hero h1 {
    font-size: 3.2rem;
    line-height: 1.1;
    margin-bottom: 16px;
}

.hero p {
    font-size: 1.08rem;
    max-width: 720px;
    margin-bottom: 22px;
}

.hero-buttons {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
}

.btn-primary,
.btn-secondary,
.btn-outline,
.button,
.flash-ok {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    padding: 12px 18px;
    border-radius: 10px;
    font-weight: bold;
    border: none;
    cursor: pointer;
    min-height: 42px;
    font-size: 0.95rem;
}

.btn-primary,
.button {
    background-color: #ee9b00;
    color: white;
}

.btn-primary:hover,
.button:hover {
    background-color: #ca6702;
}

.btn-secondary {
    background-color: rgba(255, 255, 255, 0.16);
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.35);
}

.btn-secondary:hover {
    background-color: rgba(255, 255, 255, 0.24);
}

.btn-outline {
    background: white;
    color: #005f73;
    border: 1px solid #cfd8dc;
}

.btn-outline:hover {
    background: #f8fafc;
}

.hero-panel {
    background: rgba(255, 255, 255, 0.14);
    border: 1px solid rgba(255, 255, 255, 0.22);
    backdrop-filter: blur(8px);
    border-radius: 20px;
    padding: 24px;
}

.hero-panel h2 {
    margin-bottom: 10px;
}

.hero-panel ul {
    padding-left: 18px;
}

.flash-wrapper {
    width: 90%;
    max-width: 1200px;
    margin: 24px auto 0;
}

.flash-message {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 14px 18px;
    border-radius: 12px;
    margin-bottom: 12px;
    font-weight: bold;
    box-shadow: 0 6px 16px rgba(0, 95, 115, 0.10);
}

.flash-success {
    background: #e8f7e8;
    color: #256029;
    border-left: 5px solid #2e7d32;
}

.flash-error {
    background: #fdeaea;
    color: #9b2226;
    border-left: 5px solid #9b2226;
}

.flash-info {
    background: #e8f0fe;
    color: #1d4ed8;
    border-left: 5px solid #1d4ed8;
}

.flash-actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
}

.flash-ok {
    background: white;
    color: #005f73;
    border: 1px solid #cfd8dc;
    min-height: 34px;
    padding: 8px 12px;
}

.flash-link {
    color: inherit;
    background: white;
    padding: 8px 12px;
    border-radius: 8px;
    text-decoration: none;
    border: 1px solid #cfd8dc;
    font-size: 0.9rem;
}

.container {
    width: 90%;
    max-width: 1200px;
    margin: 60px auto;
}

.summary-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    margin-bottom: 35px;
}

.summary-card {
    background: white;
    border-radius: 18px;
    padding: 22px;
    box-shadow: 0 8px 20px rgba(0, 95, 115, 0.10);
    border: 1px solid #e7ecec;
    text-align: center;
}

.summary-card strong {
    display: block;
    font-size: 2rem;
    color: #005f73;
    margin-bottom: 6px;
}

.summary-card span {
    color: #526170;
}

.summary-card.important {
    border: 2px solid #ee9b00;
}

.notice {
    background: #e0f4f1;
    border-left: 5px solid #0a9396;
    padding: 18px 20px;
    border-radius: 12px;
    margin-bottom: 35px;
    color: #005f73;
}

.library-controls {
    background: white;
    border-radius: 20px;
    padding: 22px;
    box-shadow: 0 8px 20px rgba(0, 95, 115, 0.10);
    border: 1px solid #e7ecec;
    margin-bottom: 35px;
}

.library-controls h3 {
    color: #005f73;
    margin-bottom: 12px;
}

.control-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr auto;
    gap: 12px;
}

.control-grid input,
.control-grid select {
    width: 100%;
    padding: 12px;
    border: 1px solid #cfd8dc;
    border-radius: 10px;
    font-size: 0.95rem;
}

.library-section {
    margin-bottom: 60px;
}

.section-title-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 20px;
}

.section-title-row h2 {
    color: #005f73;
    font-size: 1.9rem;
}

.section-title-row p {
    color: #526170;
    max-width: 720px;
}

.section-heading-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.section-count {
    background: white;
    color: #005f73;
    border: 1px solid #e7ecec;
    border-radius: 999px;
    padding: 8px 14px;
    font-weight: bold;
}

.section-count.priority {
    background: #fff4d6;
    color: #9a6700;
    border-color: #ee9b00;
}

.card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(285px, 1fr));
    gap: 24px;
}

.card {
    background: white;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 8px 20px rgba(0, 95, 115, 0.10);
    border: 1px solid #e7ecec;
    display: flex;
    flex-direction: column;
    min-height: 100%;
}

.card.important-card {
    border: 2px solid #ee9b00;
}

.card img {
    width: 100%;
    height: 190px;
    object-fit: cover;
    display: block;
}

.card-content {
    padding: 20px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
}

.badge-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 12px;
}

.badge {
    display: inline-block;
    padding: 6px 12px;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: bold;
}

.badge-type {
    background: #e0f4f1;
    color: #005f73;
}

.badge-location {
    background: #edf2f7;
    color: #334155;
}

.badge-saved {
    background: #fff4d6;
    color: #9a6700;
}

.badge-cultural {
    background: #ee9b00;
    color: white;
}

.badge-family {
    background: #e8f7e8;
    color: #256029;
}

.badge-booking {
    background: #edf2f7;
    color: #334155;
}

.badge-price-free {
    background: #e8f7e8;
    color: #256029;
}

.badge-price-paid {
    background: #e8f0fe;
    color: #1d4ed8;
}

.badge-price-premium {
    background: #fdeaea;
    color: #b42318;
}

.card h3 {
    color: #005f73;
    font-size: 1.28rem;
    margin-bottom: 8px;
}

.meta {
    color: #6b7280;
    font-size: 0.92rem;
    margin-bottom: 10px;
}

.card p {
    color: #334155;
    margin-bottom: 12px;
}

.star-display {
    color: #ee9b00;
    font-weight: bold;
    letter-spacing: 1px;
    margin-bottom: 10px;
}

.comment-preview {
    background: #f8fafc;
    border-left: 4px solid #0a9396;
    border-radius: 10px;
    padding: 10px;
    margin-bottom: 12px;
    font-size: 0.88rem;
}

.comment-preview strong {
    color: #005f73;
}

.card-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: auto;
    padding-top: 10px;
}

.card-actions form {
    display: flex;
}

.remove-button {
    background: #9b2226;
}

.remove-button:hover {
    background: #7a171b;
}

.empty-state {
    background: white;
    border-radius: 18px;
    padding: 32px;
    text-align: center;
    color: #526170;
    box-shadow: 0 8px 20px rgba(0, 95, 115, 0.10);
    border: 1px solid #e7ecec;
}

.empty-state h3 {
    color: #005f73;
    margin-bottom: 8px;
}

.empty-state a {
    display: inline-block;
    margin-top: 14px;
    text-decoration: none;
    background: #ee9b00;
    color: white;
    padding: 10px 16px;
    border-radius: 8px;
    font-weight: bold;
}

.empty-state a:hover {
    background: #ca6702;
}

.no-results {
    display: none;
    background: white;
    border-radius: 18px;
    padding: 28px;
    text-align: center;
    color: #526170;
    box-shadow: 0 8px 20px rgba(0, 95, 115, 0.10);
    border: 1px solid #e7ecec;
    margin-bottom: 35px;
}

.no-results h3 {
    color: #005f73;
    margin-bottom: 8px;
}

.suggestions-section {
    background: white;
    border-radius: 20px;
    padding: 28px;
    box-shadow: 0 8px 20px rgba(0, 95, 115, 0.10);
    border: 1px solid #e7ecec;
    margin-top: 40px;
}

.suggestions-section h2 {
    color: #005f73;
    margin-bottom: 14px;
}

.suggestions-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-top: 16px;
}

.suggestion-card {
    background: #f8fafc;
    border-left: 4px solid #0a9396;
    padding: 14px;
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
}

.suggestion-card strong {
    color: #005f73;
}

footer {
    background-color: #005f73;
    color: white;
    text-align: center;
    padding: 26px;
    margin-top: 70px;
}

@media (max-width: 1000px) {
    .summary-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .control-grid {
        grid-template-columns: 1fr 1fr;
    }
}

@media (max-width: 900px) {
    .hero,
    .suggestions-grid {
        grid-template-columns: 1fr;
    }

    .hero h1 {
        font-size: 2.5rem;
    }

    .flash-message {
        align-items: flex-start;
        flex-direction: column;
    }
}

@media (max-width: 600px) {
    nav {
        gap: 10px;
    }

    nav a {
        padding: 8px 12px;
        font-size: 0.95rem;
    }

    .hero h1 {
        font-size: 2.2rem;
    }

    .summary-grid,
    .control-grid {
        grid-template-columns: 1fr;
    }
}
</style>
</head>

<body>

<header>
   
    <nav>
		<a href="/home">Home</a>
		<a href="/locations">Cultural Experiences</a>
		
		<a href="/library" class="active-link">My Library</a>
		{% if user_profile == "Tourist" or user_profile == "Admin" %}
			
			<a href="/day-planner">Day Planner</a>
		{% endif %}

		{% if user_profile == "Admin" %}
			<a href="/admin">Admin</a>
		{% endif %}

		<a href="/logout">Logout</a>
	</nav>
	
	    <section class="hero">
        <div>
            <h1>My saved cultural experience library</h1>
            <p>
                Welcome, {{ user }}. Your library keeps cultural experiences first, then Olympic events and other Brisbane visitor activities underneath.
            </p>

            <div class="hero-buttons">
                <a href="#cultural-section" class="btn-primary">Cultural Experiences</a>
                <a href="#olympic-section" class="btn-secondary">Olympic Events</a>
                <a href="#activity-section" class="btn-secondary">Other Activities</a>
                <a href="/day-planner" class="btn-primary">Plan My Day</a>
            </div>
        </div>

        <div class="hero-panel">
            <h2>Your planning space</h2>
            <ul>
                <li>Save cultural experiences from the Cultural Experiences page</li>
                <li>Keep Olympic events and other visitor activities underneath</li>
                <li>Compare prices, ratings, locations and booking details</li>
                <li>Remove items when your plans change</li>
            </ul>
        </div>
    </section>
</header>

{% with messages = get_flashed_messages(with_categories=true) %}
    {% if messages %}
        <div class="flash-wrapper">
            {% for category, message in messages %}
                <div class="flash-message flash-{{ category }}">
                    <span>{{ message }}</span>
                    <div class="flash-actions">
                        <a class="flash-link" href="/library">Continue</a>
                        <button class="flash-ok" type="button" onclick="this.closest('.flash-message').remove()">OK</button>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endwith %}

<main class="container">

    {% set cultural_count = cultural_favourites|length %}
    {% set activity_count = favourites|length %}
    {% set olympic_count = olympic_favourites|length %}
    {% set total_count = cultural_count + activity_count + olympic_count %}

    <section class="summary-grid">
        <div class="summary-card important">
            <strong>{{ cultural_count }}</strong>
            <span>saved cultural experience{% if cultural_count != 1 %}s{% endif %}</span>
        </div>

        <div class="summary-card">
            <strong>{{ olympic_count }}</strong>
            <span>saved Olympic event{% if olympic_count != 1 %}s{% endif %}</span>
        </div>

        <div class="summary-card">
            <strong>{{ activity_count }}</strong>
            <span>saved visitor activit{% if activity_count == 1 %}y{% else %}ies{% endif %}</span>
        </div>

        <div class="summary-card">
            <strong>{{ total_count }}</strong>
            <span>total saved item{% if total_count != 1 %}s{% endif %}</span>
        </div>
    </section>

    <div class="notice">
        <strong>Planning tip:</strong>
        Start with cultural experiences, then add Olympic events and other nearby activities to create a balanced Brisbane itinerary.
    </div>

    <section class="library-controls">
        <h3>Search and filter your saved items</h3>

        <div class="control-grid">
            <input type="text" id="librarySearch" placeholder="Search saved items by name, location, type, price or description">

            <select id="libraryFilter">
                <option value="all">Show all saved items</option>
                <option value="cultural">Cultural experiences only</option>
                <option value="olympic">Olympic events only</option>
                <option value="activity">Other visitor activities only</option>
            </select>

            <select id="familyFilter">
                <option value="all">All activity types</option>
                <option value="family">Family friendly only</option>
            </select>

            <button class="btn-outline" type="button" id="resetLibraryFilters">Reset</button>
        </div>
    </section>

    <div class="no-results" id="noResults">
        <h3>No saved items match your search</h3>
        <p>Try a different search term or reset the filter.</p>
    </div>

    <section id="cultural-section" class="library-section">
        <div class="section-title-row">
            <div class="section-heading-text">
                <h2>Cultural Experiences</h2>
                <p>Your most important saved section: creative venues, museums, galleries, markets, performances and family-friendly cultural options.</p>
            </div>
            <span class="section-count priority">{{ cultural_count }} saved</span>
        </div>

        {% if cultural_favourites %}
            <div class="card-grid">
                {% for favourite in cultural_favourites %}
                    {% set item = favourite.cultural_experience %}

                    {% if item %}
                        {% if cultural_review_data and item.cultural_id in cultural_review_data %}
                            {% set item_rating = cultural_review_data[item.cultural_id].average %}
                            {% set item_review_count = cultural_review_data[item.cultural_id].count %}
                            {% set item_comments = cultural_review_data[item.cultural_id].comments %}
                        {% else %}
                            {% set item_rating = item.star_rating or 0 %}
                            {% set item_review_count = 0 %}
                            {% set item_comments = [] %}
                        {% endif %}

                        {% set rounded_item_rating = item_rating|round(0, 'floor')|int %}

                        <div class="card library-item important-card"
                             data-section="cultural"
                             data-family="{{ (item.family_friendly or '')|lower }}"
                             data-search="{{ (item.name ~ ' ' ~ item.category ~ ' ' ~ item.suburb ~ ' ' ~ item.description ~ ' ' ~ item.price_range ~ ' ' ~ item.cultural_tag ~ ' ' ~ item.event_type ~ ' ' ~ item.booking_required)|lower }}">

                            {% if item.image_url %}
                                <img src="{{ item.image_url }}" alt="{{ item.name }}">
                            {% endif %}

                            <div class="card-content">
                                <div class="badge-row">
                                    <span class="badge badge-cultural">★ Saved Cultural Experience</span>

                                    {% if item.category %}
                                        <span class="badge badge-type">{{ item.category }}</span>
                                    {% endif %}

                                    {% if item.family_friendly == "Yes" %}
                                        <span class="badge badge-family">Family friendly</span>
                                    {% endif %}

                                    {% if item.booking_required %}
                                        <span class="badge badge-booking">Booking: {{ item.booking_required }}</span>
                                    {% endif %}

                                    {% if item.price_range == "Free" %}
                                        <span class="badge badge-price-free">Free</span>
                                    {% elif item.price_range == "Premium" %}
                                        <span class="badge badge-price-premium">Premium</span>
                                    {% else %}
                                        <span class="badge badge-price-paid">{{ item.price_range }}</span>
                                    {% endif %}
                                </div>

                                <h3>{{ item.name }}</h3>

                                <p class="meta">
                                    {{ item.category }} | {{ item.suburb }}
                                    {% if item.event_type %}
                                        | {{ item.event_type }}
                                    {% endif %}
                                </p>

                                <div class="star-display">
                                    {% for i in range(rounded_item_rating) %}★{% endfor %}
                                    {% for i in range(5 - rounded_item_rating) %}☆{% endfor %}
                                    {% if item_review_count > 0 %}
                                        <span style="color:#526170; letter-spacing:0; font-size:0.88rem;">
                                            {{ item_review_count }} review{% if item_review_count != 1 %}s{% endif %}
                                        </span>
                                    {% endif %}
                                </div>

                                <p>{{ item.description }}</p>

                                <div class="comment-preview">
                                    {% if item_comments %}
                                        <strong>Latest comment:</strong><br>
                                        “{{ item_comments[0].comment }}”<br>
                                        <small>— {{ item_comments[0].username }}</small>
                                    {% else %}
                                        <strong>No user comments yet.</strong><br>
                                        <small>Visit Cultural Experiences to add a review.</small>
                                    {% endif %}
                                </div>

                                <div class="card-actions">
                                    {% if item.website_link %}
                                        <a class="button" href="{{ item.website_link }}" target="_blank">Learn more</a>
                                    {% endif %}

                                    <a class="btn-outline" href="/locations">View cultural page</a>

                                    <form method="POST" action="{{ url_for('remove_library_cultural_favourite', cultural_favourite_id=favourite.cultural_favourite_id) }}">
                                        <button class="button remove-button" type="submit">Remove</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        {% else %}
            <div class="empty-state">
                <h3>No cultural experiences saved yet</h3>
                <p>Save cultural experiences first so your library matches the main purpose of the website.</p>
                <a href="/locations">Browse Cultural Experiences</a>
            </div>
        {% endif %}
    </section>

    <section id="olympic-section" class="library-section">
        <div class="section-title-row">
            <div class="section-heading-text">
                <h2>Olympic Events</h2>
                <p>Saved sport or Olympic-related events you may want to attend or plan around.</p>
            </div>
            <span class="section-count">{{ olympic_count }} saved</span>
        </div>

        {% if olympic_favourites %}
            <div class="card-grid">
                {% for event in olympic_favourites %}

                    {% if olympic_review_data and event.event_id in olympic_review_data %}
                        {% set event_rating = olympic_review_data[event.event_id].average %}
                        {% set event_review_count = olympic_review_data[event.event_id].count %}
                        {% set event_comments = olympic_review_data[event.event_id].comments %}
                    {% else %}
                        {% set event_rating = 0 %}
                        {% set event_review_count = 0 %}
                        {% set event_comments = [] %}
                    {% endif %}

                    {% set rounded_event_rating = event_rating|round(0, 'floor')|int %}

                    <div class="card library-item"
                         data-section="olympic"
                         data-family=""
                         data-search="{{ (event.name ~ ' ' ~ event.category ~ ' ' ~ event.location ~ ' ' ~ event.schedule ~ ' ' ~ event.description)|lower }}">

                        <div class="card-content">
                            <div class="badge-row">
                                <span class="badge badge-saved">★ Saved Olympic Event</span>

                                {% if event.category %}
                                    <span class="badge badge-type">{{ event.category }}</span>
                                {% endif %}

                                {% if event.location %}
                                    <span class="badge badge-location">{{ event.location }}</span>
                                {% endif %}
                            </div>

                            <h3>{{ event.name }}</h3>

                            {% if event.schedule %}
                                <p class="meta">{{ event.schedule }}</p>
                            {% endif %}

                            {% if event.location %}
                                <p class="meta">Location: {{ event.location }}</p>
                            {% endif %}

                            {% if event_review_count > 0 %}
                                <div class="star-display">
                                    {% for i in range(rounded_event_rating) %}★{% endfor %}
                                    {% for i in range(5 - rounded_event_rating) %}☆{% endfor %}
                                    <span style="color:#526170; letter-spacing:0; font-size:0.88rem;">
                                        {{ event_review_count }} review{% if event_review_count != 1 %}s{% endif %}
                                    </span>
                                </div>
                            {% else %}
                                <div class="star-display" style="color:#526170; letter-spacing:0;">
                                    No reviews yet
                                </div>
                            {% endif %}

                            {% if event.description %}
                                <p>{{ event.description }}</p>
                            {% endif %}

                            <div class="comment-preview">
                                {% if event_comments %}
                                    <strong>Latest comment:</strong><br>
                                    “{{ event_comments[0].comment }}”<br>
                                    <small>— {{ event_comments[0].username }}</small>
                                {% else %}
                                    <strong>No comments yet.</strong><br>
                                    <small>Visit the Olympic Events page to add a review.</small>
                                {% endif %}
                            </div>

                            <div class="card-actions">
                                <a class="btn-outline" href="/olympic-events">View events</a>

                                <form method="POST" action="{{ url_for('remove_library_olympic_favourite', olympic_favourite_id=event.olympic_favourite_id) }}">
                                    <button class="button remove-button" type="submit">Remove</button>
                                </form>
                            </div>
                        </div>
                    </div>

                {% endfor %}
            </div>
        {% else %}
            <div class="empty-state">
                <h3>No Olympic events saved yet</h3>
                <p>Save Olympic events you are interested in and they will appear here.</p>
                <a href="/olympic-events">Browse Olympic Events</a>
            </div>
        {% endif %}
    </section>

    <section id="activity-section" class="library-section">
        <div class="section-title-row">
            <div class="section-heading-text">
                <h2>Other Featured Visitor Activities</h2>
                <p>Saved Brisbane activities that support your trip, such as food, outdoor experiences, parks and attractions.</p>
            </div>
            <span class="section-count">{{ activity_count }} saved</span>
        </div>

        {% if favourites %}
            <div class="card-grid">
                {% for favourite in favourites %}
                    {% set activity = favourite.activity %}

                    {% if activity %}
                        {% if review_data and activity.activity_id in review_data %}
                            {% set activity_rating = review_data[activity.activity_id].average %}
                            {% set activity_review_count = review_data[activity.activity_id].count %}
                            {% set activity_comments = review_data[activity.activity_id].comments %}
                        {% else %}
                            {% set activity_rating = activity.star_rating or 0 %}
                            {% set activity_review_count = 0 %}
                            {% set activity_comments = [] %}
                        {% endif %}

                        {% set rounded_activity_rating = activity_rating|round(0, 'floor')|int %}

                        <div class="card library-item"
                             data-section="activity"
                             data-family="{{ (activity.cultural_tag or '')|lower }}"
                             data-search="{{ (activity.name ~ ' ' ~ activity.category ~ ' ' ~ activity.suburb ~ ' ' ~ activity.description ~ ' ' ~ activity.price_range ~ ' ' ~ activity.cultural_tag)|lower }}">

                            {% if activity.image_url %}
                                <img src="{{ activity.image_url }}" alt="{{ activity.name }}">
                            {% endif %}

                            <div class="card-content">
                                <div class="badge-row">
                                    <span class="badge badge-saved">★ Saved Activity</span>

                                    {% if activity.category %}
                                        <span class="badge badge-type">{{ activity.category }}</span>
                                    {% endif %}

                                    {% if activity.cultural_tag and activity.cultural_tag|lower == "family friendly" %}
                                        <span class="badge badge-family">Family friendly</span>
                                    {% endif %}

                                    {% if activity.price_range == "Free" %}
                                        <span class="badge badge-price-free">Free</span>
                                    {% elif activity.price_range == "Premium" %}
                                        <span class="badge badge-price-premium">Premium</span>
                                    {% else %}
                                        <span class="badge badge-price-paid">{{ activity.price_range }}</span>
                                    {% endif %}
                                </div>

                                <h3>{{ activity.name }}</h3>

                                <p class="meta">{{ activity.category }} | {{ activity.suburb }}</p>

                                <div class="star-display">
                                    {% for i in range(rounded_activity_rating) %}★{% endfor %}
                                    {% for i in range(5 - rounded_activity_rating) %}☆{% endfor %}
                                    {% if activity_review_count > 0 %}
                                        <span style="color:#526170; letter-spacing:0; font-size:0.88rem;">
                                            {{ activity_review_count }} review{% if activity_review_count != 1 %}s{% endif %}
                                        </span>
                                    {% endif %}
                                </div>

                                <p>{{ activity.description }}</p>

                                <div class="comment-preview">
                                    {% if activity_comments %}
                                        <strong>Latest comment:</strong><br>
                                        “{{ activity_comments[0].comment }}”<br>
                                        <small>— {{ activity_comments[0].username }}</small>
                                    {% else %}
                                        <strong>No user comments yet.</strong><br>
                                        <small>Visit the Cultural Experiences page to add a review.</small>
                                    {% endif %}
                                </div>

                                <div class="card-actions">
                                    {% if activity.website_link %}
                                        <a class="button" href="{{ activity.website_link }}" target="_blank">Learn more</a>
                                    {% endif %}

                                    <a class="btn-outline" href="/locations">View page</a>

                                    <form method="POST" action="{{ url_for('remove_library_favourite', favourite_id=favourite.favourite_id) }}">
                                        <button class="button remove-button" type="submit">Remove</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        {% else %}
            <div class="empty-state">
                <h3>No other activities saved yet</h3>
                <p>Save extra visitor activities from the Cultural Experiences page and they will appear here.</p>
                <a href="/locations">Browse Activities</a>
            </div>
        {% endif %}
    </section>

    <section class="suggestions-section">
        <h2>Plan your next step</h2>
        <p>
            Your saved items can help you build a balanced Brisbane visit with culture, Olympic events,
            food, nature and downtime between major experiences.
        </p>

        <div class="suggestions-grid">
            <a href="/day-planner" class="suggestion-card">
                <strong>Build a day plan</strong>
                <p>Add saved cultural experiences and activities to your day planner.</p>
            </a>

            <a href="/locations" class="suggestion-card">
                <strong>Find more cultural experiences</strong>
                <p>Use the Cultural Experiences page to save museums, galleries, markets and family-friendly options.</p>
            </a>

            <a href="/olympic-events" class="suggestion-card">
                <strong>Add Olympic events</strong>
                <p>Save Olympic events that connect with your Brisbane visit.</p>
            </a>
        </div>
    </section>

</main>

<footer>
    <p>&copy; 2026 Brisbane Olympic Visitor Guide</p>
</footer>

<script>
const searchInput = document.getElementById("librarySearch");
const libraryFilter = document.getElementById("libraryFilter");
const familyFilter = document.getElementById("familyFilter");
const resetButton = document.getElementById("resetLibraryFilters");
const libraryItems = Array.from(document.querySelectorAll(".library-item"));
const noResults = document.getElementById("noResults");

function applyLibraryFilters() {
    const searchValue = searchInput.value.trim().toLowerCase();
    const filterValue = libraryFilter.value.toLowerCase();
    const familyValue = familyFilter.value.toLowerCase();

    let visibleCount = 0;

    libraryItems.forEach(item => {
        const searchableText = item.dataset.search || "";
        const section = item.dataset.section || "";
        const family = item.dataset.family || "";

        const matchesSearch =
            searchValue === "" || searchableText.includes(searchValue);

        const matchesSection =
            filterValue === "all" || section === filterValue;

        const matchesFamily =
            familyValue === "all" ||
            family.includes("family") ||
            family.includes("yes");

        if (matchesSearch && matchesSection && matchesFamily) {
            item.style.display = "flex";
            visibleCount++;
        } else {
            item.style.display = "none";
        }
    });

    if (visibleCount === 0 && libraryItems.length > 0) {
        noResults.style.display = "block";
    } else {
        noResults.style.display = "none";
    }
}

searchInput.addEventListener("input", applyLibraryFilters);
libraryFilter.addEventListener("change", applyLibraryFilters);
familyFilter.addEventListener("change", applyLibraryFilters);

resetButton.addEventListener("click", function () {
    searchInput.value = "";
    libraryFilter.value = "all";
    familyFilter.value = "all";
    applyLibraryFilters();
});

applyLibraryFilters();
</script>

</body>
</html>
